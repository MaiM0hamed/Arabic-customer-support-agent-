OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Free-tier model by default to keep evaluation/dev cost at $0. Switch to
# "qwen/qwen3-14b" (paid) for higher rate limits / quality in production.
OPENROUTER_MODEL=qwen/qwen3-14b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/arabic_support
LOG_LEVEL=INFO
REQUEST_TIMEOUT=30
MAX_RETRIES=3
API_KEY=
RATE_LIMIT_PER_MINUTE=30
